#!/usr/bin/env bash
#
# Git pre-push hook: runs the same checks as CI PR workflow before allowing push.
#
# Install:
#   ln -sf ../../scripts/pre-push .git/hooks/pre-push
#
# Checks mirror .github/workflows/ci.yml PR jobs:
#   - lint: golangci-lint (v2.1) + go vet
#   - unit-test: make test (go test -short)
#   - docker-build: docker build (validates Dockerfile)
#
# Prerequisites are auto-managed: PostgreSQL and MySQL containers are started
# automatically if not already running (see "Ensure DB dependencies" below).

set -euo pipefail

GOLANGCI_LINT_VERSION='v2.12'

# =============================================================================
# Job 0: ensure DB dependencies (PostgreSQL + MySQL containers)
# =============================================================================
ensure_container() {
    local name="$1" image="$2" ports="$3" env_args="$4"
    if docker inspect "$name" --format '{{.State.Running}}' 2>/dev/null | grep -q true; then
        echo "   ✅ $name already running"
        return
    fi
    # Container exists but is stopped — start it
    if docker inspect "$name" &>/dev/null; then
        echo "   ⏳ Starting existing container: $name"
        docker start "$name" >/dev/null
    else
        echo "   ⏳ Creating and starting: $name ($image)"
        # shellcheck disable=SC2086
        docker run -d --name "$name" $ports $env_args "$image" >/dev/null
    fi
    # Wait for the container to become healthy / ready
    local retries=30
    until docker inspect "$name" --format '{{.State.Running}}' 2>/dev/null | grep -q true; do
        retries=$((retries - 1))
        if [ "$retries" -le 0 ]; then
            echo "   ❌ $name failed to start"
            return 1
        fi
        sleep 1
    done
    # Give the DB a moment to accept connections
    sleep 2
    echo "   ✅ $name ready"
}

if command -v docker &>/dev/null; then
    echo "▶ [0/3] Ensuring database containers"
    ensure_container "xyncra-pg" "postgres:16" \
        "-p 5432:5432" \
        "-e POSTGRES_USER=sequify -e POSTGRES_PASSWORD=sequify -e POSTGRES_DB=sequify"
    ensure_container "xyncra-mysql" "mysql:8" \
        "-p 3306:3306" \
        "-e MYSQL_ROOT_PASSWORD=sequify -e MYSQL_USER=sequify -e MYSQL_PASSWORD=sequify -e MYSQL_DATABASE=sequify"
    echo ""
else
    echo "⚠️  docker not found — skipping DB container setup"
    echo "   Unit tests requiring PostgreSQL/MySQL will be skipped."
    echo ""
fi

echo "🔍 Running pre-push checks (mirrors CI PR jobs)..."
echo ""

# Track failures
failed=0

# =============================================================================
# Job 1: lint
# =============================================================================
echo "▶ [1/3] Lint: golangci-lint"
if command -v golangci-lint &>/dev/null; then
    installed_version=$(golangci-lint --version 2>&1 | grep -oE 'v[0-9]+\.[0-9]+' | head -1 || echo "unknown")
    echo "   Found golangci-lint ${installed_version} (CI requires ${GOLANGCI_LINT_VERSION})"
    if ! golangci-lint run ./...; then
        echo "❌ golangci-lint failed"
        failed=1
    else
        echo "✅ golangci-lint passed"
    fi
else
    echo "⚠️  golangci-lint not installed (CI requires ${GOLANGCI_LINT_VERSION})"
    echo "   Install: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${GOLANGCI_LINT_VERSION}"
fi

echo ""
echo "▶ [1/3] Lint: go vet"
if ! go vet ./...; then
    echo "❌ go vet failed"
    failed=1
else
    echo "✅ go vet passed"
fi

echo ""

# =============================================================================
# Job 2: unit-test
# =============================================================================
echo "▶ [2/3] Unit test: make test"
if ! make test; then
    echo "❌ unit tests failed"
    failed=1
else
    echo "✅ unit tests passed"
fi

echo ""

# =============================================================================
# Job 3: docker-build
# =============================================================================
echo "▶ [3/3] Docker build"
if command -v docker &>/dev/null; then
    if ! docker build -t xyncra-server:pre-push-check -f deploy/Dockerfile . >/dev/null 2>&1; then
        echo "❌ docker build failed"
        failed=1
    else
        echo "✅ docker build passed"
    fi
else
    echo "⚠️  docker not installed, skipping"
fi

echo ""

# =============================================================================
# Result
# =============================================================================
if [ $failed -ne 0 ]; then
    echo "🚫 Pre-push checks failed. Push aborted."
    exit 1
fi

echo "✅ All pre-push checks passed. Proceeding with push."
exit 0
