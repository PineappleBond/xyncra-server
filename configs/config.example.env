# Xyncra Server Configuration
# Copy this file to .env and adjust the values for your environment.

# ---------------------------------------------------------------------------
# WebSocket Server
# ---------------------------------------------------------------------------

# Address the WebSocket server listens on.
XYNCRA_ADDR=:8080

# ---------------------------------------------------------------------------
# Redis (used for ConnectionStore and message Broker)
# ---------------------------------------------------------------------------

# Redis server address in "host:port" format.
XYNCRA_REDIS_ADDR=localhost:6379

# Redis AUTH password. Leave empty if authentication is disabled.
XYNCRA_REDIS_PASSWORD=

# Redis database index (0-15 by default).
XYNCRA_REDIS_DB=0

# ---------------------------------------------------------------------------
# Database (SQLite, PostgreSQL, or MySQL via GORM)
# ---------------------------------------------------------------------------

# Database driver: "sqlite", "postgres", or "mysql".
XYNCRA_DB_DRIVER=sqlite

# Database DSN (connection string).
#   SQLite example:    xyncra.db
#   PostgreSQL example: host=localhost user=xyncra password=secret dbname=xyncra port=5432 sslmode=disable
#   MySQL example:     xyncra:secret@tcp(localhost:3306)/xyncra?parseTime=true
XYNCRA_DB_DSN=xyncra.db

# ---------------------------------------------------------------------------
# Connection Limits
# ---------------------------------------------------------------------------

# Maximum number of active connections per user.
# A value of 0 means unlimited.
XYNCRA_MAX_CONNS_PER_USER=0
