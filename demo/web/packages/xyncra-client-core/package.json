{
  "name": "@xyncra/client-core",
  "version": "0.1.0",
  "description": "Core interfaces, errors, constants, and options for the Xyncra TypeScript client",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xyncra/protocol": "*",
    "dexie": "^4.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "fake-indexeddb": "^6.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
