{
  "name": "@xyncra/client-web",
  "version": "0.1.0",
  "description": "Browser adapters and React hooks for the Xyncra TypeScript client",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build --force",
    "test": "jest --config jest.config.cjs",
    "typecheck": "tsc --noEmit",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@xyncra/protocol": "*",
    "@xyncra/client-core": "*",
    "dexie": "^4.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "antd": "^5.0.0 || ^6.0.0",
    "@ant-design/icons": "^5.0.0 || ^6.0.0",
    "@ant-design/x": "^1.0.0 || ^2.0.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.0.0 || ^6.0.0",
    "@ant-design/x": "^1.0.0 || ^2.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.0.0 || ^19.0.0",
    "antd": "^5.0.0 || ^6.0.0",
    "fake-indexeddb": "^6.0.0",
    "jest": "^29.7.0",
    "react": "^18.0.0 || ^19.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
