{
  "name": "@xyncra/client-cli",
  "version": "0.1.0",
  "description": "Node.js CLI runtime for Xyncra \u2014 daemon, IPC, and CLI commands",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "xyncra-client": "./dist/bin/xyncra-client.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xyncra/protocol": "*",
    "@xyncra/client-core": "*",
    "commander": "^13.0.0",
    "ws": "^8.18.0",
    "fs-ext": "^2.0.0",
    "uuid": "^11.0.0",
    "fake-indexeddb": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
